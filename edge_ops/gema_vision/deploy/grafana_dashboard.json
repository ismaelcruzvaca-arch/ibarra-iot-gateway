{
  "__inputs": [
    {
      "name": "DS_MQTT",
      "label": "MQTT Data Source",
      "description": "Grafana MQTT data source subscribing to novamex/vision/telemetry",
      "type": "datasource",
      "pluginId": "mqtt-datasource",
      "pluginName": "MQTT"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "mqtt-datasource",
      "name": "MQTT",
      "version": "1.0.0"
    }
  ],
  "title": "GEMA Vision — Cámara Industrial",
  "description": "Dashboard en tiempo real para el pipeline de visión industrial GEMA V3.0 sobre Rockchip RV1106.",
  "tags": ["gema", "vision", "rv1106", "industrial"],
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "title": "Temperatura del SoC",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 0},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 95,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 65},
              {"color": "orange", "value": 75},
              {"color": "red",    "value": 85}
            ]
          },
          "unit": "celsius"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "soc_temp_c"
        }
      ]
    },
    {
      "title": "FPS — Cuadros por Segundo",
      "type": "stat",
      "gridPos": {"h": 6, "w": 3, "x": 4, "y": 0},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 1.0},
              {"color": "green",  "value": 1.4}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "fps"
        }
      ]
    },
    {
      "title": "Frames Procesados",
      "type": "stat",
      "gridPos": {"h": 6, "w": 3, "x": 7, "y": 0},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "frames_processed"
        }
      ]
    },
    {
      "title": "Defectos Detectados",
      "type": "stat",
      "gridPos": {"h": 6, "w": 3, "x": 10, "y": 0},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "orange", "value": 10},
              {"color": "red",    "value": 50}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "defects_total"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"h": 6, "w": 3, "x": 13, "y": 0},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "uptime_sec"
        }
      ]
    },
    {
      "title": "FPS en el tiempo",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 6},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 1.0},
              {"color": "green",  "value": 1.4}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "hidden"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "fps"
        }
      ]
    },
    {
      "title": "Temperatura SoC en el tiempo",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 6},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 95,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 65},
              {"color": "orange", "value": 75},
              {"color": "red",    "value": 85}
            ]
          }
        }
      },
      "options": {
        "legend": {"displayMode": "hidden"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "soc_temp_c"
        }
      ]
    },
    {
      "title": "Memoria Residente (VmRSS)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 14},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 131072,
          "unit": "decks",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 65536},
              {"color": "red",    "value": 98304}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "heap_resident_kb"
        }
      ]
    },
    {
      "title": "Frames Descartados (Drop-Oldest)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 3, "x": 4, "y": 14},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "orange", "value": 10},
              {"color": "red",    "value": 100}
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "frames_dropped"
        }
      ]
    },
    {
      "title": "Último Defecto",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 7, "y": 14},
      "datasource": "${DS_MQTT}",
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "colorMode": "value"
        }
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "query": "novamex/vision/telemetry",
          "field": "last_defect_ts"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
