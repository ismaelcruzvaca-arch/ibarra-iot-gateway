# ============================================================================
# gema-vision.env  —  Environment variables for the vision daemon
#
# Installed at:  /etc/gema-vision.env
# Loaded by:     gema-vision.service (EnvironmentFile directive)
# ============================================================================

# Camera device index
GEMA_CAMERA_INDEX=0

# MQTT broker
GEMA_MQTT_BROKER=tcp://mosquitto:1883
GEMA_MQTT_CLIENT_ID=gema-vision-rv1106

# Inference model path (RKNN)
GEMA_MODEL_PATH=/userdata/gema-vision/model/yolov5n.rknn

# Watchdog device
GEMA_WATCHDOG_DEVICE=/dev/watchdog
GEMA_WATCHDOG_INTERVAL_SEC=5

# Log level: debug, info, warn, error
GEMA_LOG_LEVEL=info
